# Credenciales de Supabase (Project Settings → API)
# Copiá este archivo a .env.local y completá los valores reales.
# En Netlify: Site settings → Environment variables (con el prefijo VITE_).
# NO commitear .env.local — solo este .env.example.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Clave del panel admin interno (/admin). Protección básica del lado del cliente.
VITE_ADMIN_PASSWORD=cambiá-esta-clave
